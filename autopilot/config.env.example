# =============================================================================
# Autopilot Configuration (machine-local, DO NOT commit)
# Copy this to config.env and fill in your values:
#   cp config.env.example config.env
# =============================================================================

# --- Project ---
# Absolute path to the project root
PROJECT_DIR=""

# Where worktrees are created (defaults to ~/worktrees/<project-name>)
# WORKTREES_BASE="$HOME/worktrees/myproject"

# --- Git ---
# Base branch to create worktrees from (e.g., main, master, develop)
BASE_BRANCH="main"

# --- Jira ---
# Jira project key (e.g., ECH, PROJ, MYAPP)
JIRA_PROJECT=""

# Label that triggers autopilot pickup (must exist in your Jira project)
JIRA_LABEL="claude-autopilot"

# Path to file containing Jira credentials (needs JIRA_BASE_URL, JIRA_EMAIL, JIRA_API_TOKEN)
# Defaults to $PROJECT_DIR/.env.local
# JIRA_CREDENTIALS_FILE="$PROJECT_DIR/.env.local"

# --- Claude ---
# Override Claude binary path (auto-detected from PATH if not set)
# CLAUDE_BIN="/path/to/claude"

# --- Tmux ---
# Path to tmux helper scripts (defaults to ~/.config/tmux/scripts)
# TMUX_SCRIPTS="$HOME/.config/tmux/scripts"

# --- Dev Server ---
# Command to start the dev server (run in the "server" tmux pane)
# The tmux pane has $SERVER_PORT set automatically by create-worktree-session.sh
# Leave empty to skip auto-starting the server
DEV_SERVER_CMD=""
# Examples:
#   DEV_SERVER_CMD="PORT=\$SERVER_PORT bun run dev"
#   DEV_SERVER_CMD="PORT=\$SERVER_PORT npm run dev"
#   DEV_SERVER_CMD="PORT=\$SERVER_PORT yarn dev"
#   DEV_SERVER_CMD="cargo run -- --port \$SERVER_PORT"

# --- Dependency Install ---
# Command to install dependencies in a new worktree (leave empty to skip)
INSTALL_CMD=""
# Examples:
#   INSTALL_CMD="bun install"
#   INSTALL_CMD="npm ci"
#   INSTALL_CMD="yarn install --frozen-lockfile"
#   INSTALL_CMD="cargo build"

# --- Worktree Setup Hook ---
# Optional script to run after worktree creation (e.g., copy env files, generate configs)
# Receives these environment variables: WORKTREE_PATH, PROJECT_DIR, WORKTREE_PORT, WORKTREE_NAME
# WORKTREE_SETUP_HOOK="$PROJECT_DIR/.autopilot/setup-worktree.sh"
