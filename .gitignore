claude/paste-cache/
claude/projects/
claude/session-env/
claude/shell-snapshots/
claude/stats-cache.json
claude/statsig/
claude/tasks/
claude/telemetry/
claude/todos/
claude/plans/
claude/settings.local.json
claude/settings.json.backup
claude/score.json
claude/cclsp.json
claude/test-*.ts
claude/test_*.py
claude/brag-book.md
claude/gsd-file-manifest.json
claude/package.json
claude/plugins/marketplaces/
claude/commands/gsd/*.bak
!cursor/
!cursor/**

# Exclude machine-specific Claude files
.claude/settings.local.json
.claude/score.json
.claude/cclsp.json

!tmux/
!tmux/**
!claude/
!claude/**

# Exclude TPM plugins (should be installed locally, not committed)
tmux/plugins/tmux-continuum/
tmux/plugins/tmux-resurrect/
tmux/plugins/tmux-sensible/
tmux/plugins/tpm/

# Exclude Zed runtime and cache files
zed/.tmp*
zed/conversations/
zed/embeddings/
zed/prompts/

!starship.toml
